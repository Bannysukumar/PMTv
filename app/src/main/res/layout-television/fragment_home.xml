<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".HomeFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Elevated Player Canvas (OTT Style) - Larger for TV -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/playerContainer"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@android:color/black"
                app:cardCornerRadius="16dp"
                app:cardElevation="12dp">

                <!-- Video Player -->
                <androidx.media3.ui.PlayerView
                    android:id="@+id/playerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:controller_layout_id="@layout/custom_exo_playback_control_view"
                    app:show_timeout="3000"
                    app:use_controller="true"
                    android:focusable="true"
                    android:nextFocusDown="@+id/btn_pip" />

                <!-- Gestures Overlay - Hidden on TV or disabled in code -->
                <include
                    android:id="@+id/gestureOverlay"
                    layout="@layout/overlay_gestures"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Current Program Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_current_program"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Morning News Bulletin"
                        android:textColor="?attr/android:textColorPrimary"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="?attr/colorSecondary" />

                        <TextView
                            android:id="@+id/tv_viewer_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/poppins_medium"
                            android:text="1.2K"
                            android:textColor="?attr/android:textColorSecondary"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="Live News \u2022 08:00 AM - 09:00 AM"
                    android:textColor="?attr/android:textColorSecondary"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Action Buttons (Cast, PiP, Share) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pip"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_medium"
                    android:text="PiP Mode"
                    android:textSize="16sp"
                    android:focusable="true"
                    android:nextFocusUp="@+id/playerView"
                    android:nextFocusRight="@+id/btn_share"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_crop" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Share"
                    android:textSize="16sp"
                    android:focusable="true"
                    android:nextFocusUp="@+id/playerView"
                    android:nextFocusLeft="@+id/btn_pip"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_share" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="@color/glass_border" />

            <!-- Breaking News Horizontal Recycler -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Breaking News"
                android:textColor="?attr/android:textColorPrimary"
                android:textSize="20sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_breaking_news"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:focusable="true"
                tools:listitem="@layout/item_news_card" />

            <!-- Upcoming Schedules Vertical Recycler -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Up Next"
                    android:textColor="?attr/android:textColorPrimary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_view_all_schedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="@font/poppins_medium"
                    android:text="View All"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_upcoming_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:focusable="true"
                tools:listitem="@layout/item_schedule" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
