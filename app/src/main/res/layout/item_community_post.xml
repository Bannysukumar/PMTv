<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1AFFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#33FFFFFF">
                
                <ImageView
                    android:id="@+id/ivPostAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/text_secondary_dark"
                    android:padding="8dp"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvPostAuthorName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPostTimestamp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Just now"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins"/>
            </LinearLayout>

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/text_secondary_dark" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPostContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is an awesome community post! Looking forward to the upcoming updates."
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/ivPostImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#33000000"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnLike"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                app:icon="@android:drawable/ic_menu_always_landscape_portrait"
                app:iconTint="@color/text_secondary_dark"
                android:textColor="@color/text_secondary_dark"
                android:fontFamily="@font/poppins"/>

            <Button
                android:id="@+id/btnDislike"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                app:icon="@android:drawable/ic_menu_always_landscape_portrait"
                app:iconTint="@color/text_secondary_dark"
                android:textColor="@color/text_secondary_dark"
                android:fontFamily="@font/poppins"
                android:rotation="180"/>
                
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnComment"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Comments"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/text_secondary_dark"
                android:textColor="@color/text_secondary_dark"
                android:fontFamily="@font/poppins"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
