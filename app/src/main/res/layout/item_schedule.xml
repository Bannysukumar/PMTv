<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1AFFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_glass_rounded"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvScheduleTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvScheduleAmPm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AM"
                android:textColor="@color/electric_blue"
                android:textSize="12sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvProgramName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Morning Debate"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="@font/poppins"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvProgramHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hosted by John Doe"
                android:textColor="@color/text_secondary_dark"
                android:textSize="14sp"
                android:fontFamily="@font/poppins"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSetReminder"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="@color/electric_blue" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
