<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false">

    <!-- Brightness/Volume Indicator (Center) -->
    <LinearLayout
        android:id="@+id/gestureIndicatorContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_rounded"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">
            
            <ProgressBar
                android:id="@+id/gestureProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@drawable/circular_progress"
                android:max="100"
                android:progress="75" />
                
            <ImageView
                android:id="@+id/gestureIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="@android:color/white" />
        </FrameLayout>
            
        <TextView
            android:id="@+id/gestureText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="75%"
            android:textColor="@android:color/white"
            android:fontFamily="@font/poppins"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Double Tap Left (Seek Back) -->
    <LinearLayout
        android:id="@+id/seekLeftContainer"
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:background="@drawable/ripple_bg_left"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_replay_10"
            app:tint="@color/white" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="-10s"
            android:fontFamily="@font/poppins"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Double Tap Right (Seek Forward) -->
    <LinearLayout
        android:id="@+id/seekRightContainer"
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:background="@drawable/ripple_bg_right"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_forward_10"
            app:tint="@color/white" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="+10s"
            android:fontFamily="@font/poppins"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Screen Locked Overlay Text -->
    <TextView
        android:id="@+id/tvScreenLocked"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen Locked"
        android:fontFamily="@font/poppins"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_glass_rounded"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Unlock Button (Floating when screen is locked and user taps) -->
    <ImageView
        android:id="@+id/btnUnlock"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/ripple_glass_circle"
        android:src="@android:drawable/ic_secure"
        app:tint="@color/white"
        android:padding="12dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
